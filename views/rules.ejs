<!doctype html>
<html lang="en">
<%- include('./layouts/header'); -%>

<style>
  /* ========================
  RULES PAGE
  ======================== */

  .rules-card {
    max-width: 1600px;
    width: 90%;
    margin: 20px auto;
    padding: 10px;

    background: rgba(255, 255, 255, 0.06);
    border-radius: 14px;

    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.15);
  }

  .rules-frame {
    width: 100%;
    height: 88vh;

    border: none;
    border-radius: 10px;

    background: white;
  }

  /* desktop */
  .rules-desktop {
    display: block;
  }

  .rules-mobile {
    display: none;
  }

  /* iframe */
  .rules-frame {
    width: 100%;
    height: 88vh;
    border: none;
    border-radius: 10px;
    background: white;
  }

  /* mobile fallback */
  .mobile-rules-card {
    text-align: center;
    padding: 24px 18px;

    background: rgba(255, 255, 255, 0.05);
    border-radius: 12px;
  }

  .mobile-rules-card h3 {
    color: white;
    margin-bottom: 10px;
  }

  .mobile-rules-card p {
    color: rgba(255, 255, 255, 0.75);
    margin-bottom: 18px;
  }

  .mobile-rules-card a {
    display: inline-block;
    padding: 10px 18px;

    border-radius: 8px;

    background: rgba(255, 255, 255, 0.12);
    color: #d8f5d8;

    transition: all 0.2s ease;
  }

  .mobile-rules-card a:hover {
    background: rgba(255, 255, 255, 0.18);
  }

  /* MOBILE */
  @media (max-width: 768px) {

    .rules-desktop {
      display: none;
    }

    .rules-mobile {
      display: block;
    }

    .rules-card {
      width: 96%;
      padding: 12px;
    }
  }
</style>

<body>

  <%- include('./layouts/navbar'); -%>


  <div class="rules-card">

    <div class="gallery-header">
      <h1>League Rules</h1>
      <p>Bottoms Up Golf League • 2026 Season</p>
    </div>

    <!-- Desktop PDF Viewer -->
    <div class="rules-desktop">
      <iframe class="rules-frame" src="/docs/Bottoms Up 2026 League Info and Rules (03-29-26).pdf">
      </iframe>
    </div>

    <!-- Mobile Fallback -->
    <div class="rules-mobile">
      <div class="mobile-rules-card">
        <h3>League Rules PDF</h3>
        <p>
          For the best viewing experience on mobile,
          open the rules document directly.
        </p>

        <a href="/docs/Bottoms Up 2026 League Info and Rules (03-29-26).pdf" target="_blank">
          Open Rules PDF
        </a>
      </div>
    </div>

  </div>


  <%- include('./layouts/footer'); -%>

  <%- include('./layouts/scripts'); -%>
</body>

</html>