<!doctype html>
<html lang="en">

<head>
  <!-- Include global head metadata -->
  <%- include('./partials/header'); -%>
  <link rel="stylesheet" href="/assets/css/scorecard.css" />
  <link rel="stylesheet" href="/assets/css/tee-times.css" />
</head>

<body>
  <%- include('./partials/navbar'); %>
  <div class="main-wrapper">
    <!-- Page Header Banner -->
    <div class="gallery-header">
      <h1>Tee Times</h1>
      <p>Bottoms Up Golf League • 2026 Season</p>
      <h6>
        <span class="tees-red">Red</span> /
        <span class="tees-white">White</span>
        Tees
      </h6>
    </div>
    <!-- Action Panel Dashboard Controls (Only Visible if Admin is Authenticated) -->
    <% if (locals.isAdmin) { %>
    <div class="dashboard-controls">
      <!-- Week Selector Nav Dropdown -->
      <div class="control-group">
        <label for="weekSelect" class="control-label">📅 Select Week</label>
        <select id="weekSelect" class="select-dropdown" onchange="window.location.href='/tee-times?week=' + this.value">
          <% weeks.forEach(function(w) { %>
          <!-- prettier-ignore -->
          <option value="<%= w.week_number %>" <% if (weekId === w.week_number) { %>selected<% } %>>
            Week <%= w.week_number %> (<%= w.displayDate %>)
          </option>
          <% }); %>
        </select>
      </div>

      <!-- Scramble Action Generator -->
      <div class="control-group">
        <form action="/groupings/generate/<%= weekId %>" method="POST" style="margin: 0;">
          <button type="submit" class="btn-shuffle">
            🎲 Scramble & Assign Week <%= weekId %>
          </button>
        </form>
      </div>
    </div>
    <% } %>

    <!-- Card Container -->
    <div class="tee-card">

      <!-- Card Header -->
      <div class="tee-card-header">
        <h2 class="tee-sheet-title">
          Week <%= currentWeek.week_number %>
          (<%= currentWeek.displayDate %>)
          Tee Times
        </h2>
        <div class="update-chip">
          <span class="update-label">Updated</span>
          <span class="update-value"><%= lastUpdated %></span>
        </div>
      </div>

      <div class="table-wrapper">
        <table class="tee-table">
          <thead>
            <tr class="table-times">
              <th>4:50 PM</th>
              <th>5:00 PM</th>
              <th>5:10 PM</th>
              <th>5:20 PM</th>
            </tr>
          </thead>
          <!-- prettier-ignore -->
          <tbody>
            <% if (groupings && groupings.length > 0) { %>
            <% for (let posIdx = 0; posIdx < 4; posIdx++) { %>
            <tr>
              <% for (let groupIdx = 0; groupIdx < 4; groupIdx++) { %>
              <% const currentGroup = groupings.find(g => g.groupNumber === (groupIdx + 1));
                 const player = currentGroup && currentGroup.players
                 ? currentGroup.players.find(p => p.position === (posIdx + 1)) : null;
              %>
              <td
  class="<%= locals.isAdmin ? 'draggable-cell' : '' %>"

  <% if (locals.isAdmin) { %>
    ondragover="handleDragOver(event)"
    ondragenter="handleDragEnter(event)"
    ondragleave="handleDragLeave(event)"
    ondrop="handleDrop(event)"
  <% } %>

  <% if (locals.isAdmin && player) { %>
    draggable="true"
    ondragstart="handleDragStart(event)"
  <% } %>

  data-member-id="<%= player ? player.memberId : '' %>"
  data-group="<%= groupIdx + 1 %>"
  data-position="<%= posIdx + 1 %>"
>
                <% if (player) { %>
                <span style="color:black;font-weight:500;pointer-events:none;">
                  <%= player.name %>
                </span>
                <% } else { %>

                <span class="vacant-slot" style="pointer-events:none;">
                  OPEN
                </span>
                <% } %>
              </td>
              <% } %>
            </tr>
            <% } %>
            <% } else { %>
            <tr>
              <td colspan="4" style="text-align:center;padding:40px;">
                No groupings generated.
              </td>
            </tr>
            <% } %>
          </tbody>
        </table>
      </div>

      <h5 class="tee-note">
        (we will adjust if needed at the course)
      </h5>

    </div>
    <!-- Side-by-Side Roster Management Area (Enhanced for Drop Targets) -->
    <% if (groupings && groupings.length > 0) { %>
    <div
      style="display: grid; grid-template-columns: repeat(auto-fit, minmax(340px, 1fr)); gap: 20px; margin-top: 35px;">

      <!-- Column 1: Out For Week (Regulars Container Target) -->
     <!-- <div class="out-section"
        <%- locals.isAdmin ? `ondragover="handleDragOver(event)" ondragenter="handleDragEnter(event)" ondragleave="handleDragLeave(event)" ondrop="handlePoolDrop(event)"` : '' %>
        style="text-align: left; padding: 20px; transition: background-color 0.2s;">
        <h3 class="out-title" style="justify-content: flex-start; color: #e53e3e; pointer-events: none;">
          <span>🚫</span> Out for Week <%= weekId %>
        </h3>
        <div class="badge-container" style="justify-content: flex-start; pointer-events: none;">
          <% if (outPlayers && outPlayers.length > 0) { %>
          <% outPlayers.forEach(function(player) { %>
          <span class="player-badge <%= locals.isAdmin ? 'draggable-badge' : '' %>"
            <%- locals.isAdmin ? `draggable="true" ondragstart="handleDragStart(event)"` : '' %>
            data-member-id="<%= player.id %>" data-group="" data-position="" style="pointer-events: auto;">
            <%= player.name %>
          </span>
          <% }); %>
          <% } else { %>
          <span class="nobody-out">None</span>
          <% } %>
        </div>
      </div>
    -->
      <!-- Column 2: Available Substitutes Bench Container Target -->
      <div class="out-section"
        <%- locals.isAdmin ? `ondragover="handleDragOver(event)" ondragenter="handleDragEnter(event)" ondragleave="handleDragLeave(event)" ondrop="handlePoolDrop(event)"` : '' %>
        style="text-align: left; padding: 20px; border-left: 5px solid var(--accent-gold); transition: background-color 0.2s;">
        <h3 class="out-title" style="justify-content: flex-start; color: var(--primary-green); pointer-events: none;">
          <span>🏌️‍♂️</span> Available for Week <%= weekId %>
        </h3>
        <div class="badge-container" style="justify-content: flex-start; pointer-events: none;">
          <% if (locals.subPlayers && subPlayers.length > 0) { %>
          <% subPlayers.forEach(function(player) { %>
          <span class="player-badge <%= locals.isAdmin ? 'draggable-badge' : '' %>"
            <%- locals.isAdmin ? `draggable="true" ondragstart="handleDragStart(event)"` : '' %>
            data-member-id="<%= player.id %>" data-group="" data-position=""
            style="background-color: #f7fafc; color: #2d3748; border-color: #cbd5e0; pointer-events: auto;">
            <%= player.name %>
          </span>
          <% }); %>
          <% } else { %>
          <span class="nobody-out">No substitutes available.</span>
          <% } %>
        </div>
      </div>

    </div>
    <% } %>

  </div> <!-- /main-wrapper -->

  <%- include('partials/footer'); %>
  <%- include('partials/scripts'); %>

  <!-- Interactive Column Hover Highlighter Script Injection Block -->
  <script>
    const table = document.querySelector(".tee-table");
    let currentCol = -1;

    table.addEventListener("pointerover", (e) => {
      const cell = e.target.closest("td, th");
      if (!cell) return;

      const row = cell.parentElement;
      if (row.closest("thead")) return; // Skip headers

      const col = cell.cellIndex;
      if (col === currentCol) return;
      currentCol = col;

      // Remove previous highlighting states
      table.querySelectorAll(".active-col").forEach((el) => {
        el.classList.remove("active-col");
      });

      // Apply target highlight style downward into the selected column slot matrix cells
      table.querySelectorAll('tbody tr').forEach(r => {
        const target = r.children[col];
        if (target) target.classList.add('active-col');
      });
    });

    table.addEventListener("pointerleave", () => {
      currentCol = -1;
      table.querySelectorAll(".active-col").forEach((el) => {
        el.classList.remove("active-col");
      });
    });
  </script>


  <script>
    let draggedElement = null;

    function handleDragStart(e) {
      draggedElement = e.currentTarget;
      e.dataTransfer.effectAllowed = "move";
    }

    function handleDragOver(e) {
      e.preventDefault();
      e.dataTransfer.dropEffect = "move";
    }

    function handleDragEnter(e) {
      e.preventDefault();
      const target = e.currentTarget;
      if (target === draggedElement) return;

      if (target.tagName === "TD") {
        target.classList.add("drag-enter-cell");
      } else if (target.classList.contains("player-badge")) {
        target.classList.add("drag-enter-badge");
      }
    }

    function handleDragLeave(e) {
      const target = e.currentTarget;
      target.classList.remove("drag-enter-cell", "drag-enter-badge");
    }

    async function handleDrop(e) {
       e.preventDefault();
      console.error("ENTERED handleDrop");     
     
      const targetElement = e.currentTarget;

      // Clean up visual classes immediately on drop execution
      targetElement.classList.remove("drag-enter-cell", "drag-enter-badge");

      if (!draggedElement || draggedElement === targetElement) return;

      // Package target coordinate objects
      const p1 = {
        memberId: draggedElement.getAttribute("data-member-id"),
        groupNumber: draggedElement.getAttribute("data-group"),
        position: draggedElement.getAttribute("data-position")
      };

      const p2 = {
        memberId: targetElement.getAttribute("data-member-id"),
        groupNumber: targetElement.getAttribute("data-group"),
        position: targetElement.getAttribute("data-position")
      };
      console.log("p1", p1);
        console.log("p2", p2);     
      // Safety breakout if dragging/dropping over text placeholders with no user payload
      if (!p1.memberId) return;;
 
      try {
         
        const response = await fetch("/groupings/swap", {
          method: "PUT",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            weekId: "<%= weekId %>",
            player1: p1,
            player2: p2
          })
        });

        const result = await response.json();
        if (result.success) {
          window.location.reload();
        } else {
          alert("Failed to swap players: " + result.error);
        }
      } catch (err) {
        console.error("Error sending swap payload:", err);
      }

    }
  </script>
  <script>
    /**
     * Handles dropping a player element directly into an unassigned pool container.
     * Sets target parameters to blank, prompting the service layer to clear the cell.
     */
    async function handlePoolDrop(e) {
      e.preventDefault();
      const targetContainer = e.currentTarget;

      // Clean up visual indicator styles immediately
      targetContainer.classList.remove("drag-enter-cell");

      if (!draggedElement) return;

      // Extract the original cell parameters from the dragged player
      const p1 = {
        memberId: draggedElement.getAttribute("data-member-id"),
        groupNumber: draggedElement.getAttribute("data-group"),
        position: draggedElement.getAttribute("data-position")
      };

      // If the player was already in a pool, dragging them to another pool is a no-op
      if (!p1.groupNumber) return;

      // Build an empty coordinate payload to signal a cell clearance command
      const p2 = {
        memberId: null,
        groupNumber: null,
        position: null
      };

      try {
        const response = await fetch("/groupings/swap", {
          method: "PUT",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            weekId: "<%= weekId %>",
            player1: p1,
            player2: p2
          })
        });

        const result = await response.json();
        if (result.success) {
          window.location.reload();
        } else {
          alert("Failed to move player off grid: " + result.error);
        }
      } catch (err) {
        console.error("Error clearing grid slot coordinate:", err);
      }
    }
  </script>
</body>

</html>