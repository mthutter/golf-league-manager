<!doctype html>
<html lang="en">

<%- include('./layouts/header'); -%>

<body class="p-4">

  <%- include('layouts/navbar'); %>

  <div class="container">
    <h1 class="mb-4">
      League Players
    </h1>
    <table class="table table-striped table-bordered">
      <thead class="table-success">
        <tr>
          <th>ID</th>
          <th>Last Name</th>
          <th>First Name</th>
          <th>Phone</th>
          <th>Handicap</th>
          <th>Email</th>
          <th>Joined</th>
        </tr>

      </thead>

      <tbody>

        <% players.forEach(player => { %>

        <tr>
          <td>
            <%= player.id %>
          </td>
          <td>
            <%= player.name_last %>
          </td>
          <td>
            <%= player.name_first %>
          </td>
          <td>
            <%= player.phone %>
          </td>
          <td>
            <%= player.handicap %>
          </td>
          <td>
            <%= player.e_mail %>
          </td>
          <td>
            <%= player.year_joined %>
          </td>
        </tr>

        <% }) %>

      </tbody>

    </table>

  </div>

</body>

</html>