<!doctype html>
<html lang="en">
  <%- include('./layouts/header'); -%> <%- include('./layouts/navbar'); -%>
  <style>
    a {
      color: rgb(8, 70, 6);
      font-size: larger;
      font-weight: bolder;
    }

    h2 {
      text-decoration: none;
    }
  </style>

  <body>
    <div class="container-fluid">
      <div style="margin: 25px" class="row">
        <div class="col-4 text-center">
          <h2>2025 Skins Results</h2>
          <br />
          <ul style="list-style-type: none; padding: 0">
            <li>
              <button style="background-color: gray" class="button-3">Week 1 - May 5th (RAINOUT)</button>
            </li>
            <li>
              <button class="button-3" role="button" onclick="openPDF('Week 2 Skins.pdf')">Week 2 - May 12th</button>
            </li>
            <li>
              <button style="background-color: gray" class="button-3">Week 3 - May 19th (RAINOUT)</button>
            </li>
            <li>
              <button style="background-color: gray" class="button-3">Week 4 - May 26 (NOT ENOUGH PLAYERS)</button>
            </li>
            <li>
              <button style="background-color: gray" class="button-3" role="button" onclick="openPDF('3-16 Newsletter.pdf')">Week 5 - June 2 (TBD)</button>
            </li>
          </ul>
        </div>

        <div class="col-6">
          <div>
            <iframe height="75%" width="60%" style="position: absolute" src="results/2025/Week 2 Skins.pdf#view=Fit"></iframe>
            <!-- <iframe id="myFrame"></iframe> -->
          </div>
          <div>
            <object id="myFrame"></object>
          </div>
        </div>
      </div>
    </div>
  </body>

  <script type="text/javascript">
    function openPDF(filename) {
      var omyFrame = document.getElementById("myFrame");
      omyFrame.height = "75%";
      omyFrame.width = "60%";
      omyFrame.style.position = "absolute";
      // omyFrame.src = "/docs/newsletter/" + filename + "#view=FitH";
      omyFrame.data = "results/2025/" + filename + "#view=Fit";
      omyFrame.type = "application/pdf";
    }
  </script>

  <%- include('layouts/scripts'); %>
</html>

<%- include('layouts/footer'); %>
