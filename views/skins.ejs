<%
const weeks = [
  { num: 1, date: "May 5", enabled: false },
  { num: 2, date: "May 12", enabled: true },
  { num: 3, date: "May 19", enabled: false },
  { num: 4, date: "May 26", enabled: false },
  { num: 5, date: "June 2", enabled: true },
  { num: 6, date: "June 9", enabled: true },
  { num: 7, date: "June 16", enabled: true },
  { num: 8, date: "June 23", enabled: true },
  { num: 9, date: "June 30", enabled: true },
  { num: 10, date: "July 7", enabled: true },
  { num: 11, date: "July 14", enabled: true },
  { num: 12, date: "July 21", enabled: true },
  { num: 13, date: "July 28", enabled: true },
  { num: 14, date: "August 4", enabled: true },
  { num: 15, date: "August 11", enabled: true },
  { num: 16, date: "August 18", enabled: true },
  { num: 17, date: "August 25", enabled: false },
  { num: 18, date: "September 1", enabled: false },
  { num: 19, date: "September 8", enabled: false },
  { num: 20, date: "September 15", enabled: true },
  { num: 21, date: "September 22", enabled: true, current: true },
  { num: 22, date: "September 29", enabled: false }
];
%>

<!doctype html>
<html lang="en">
<head>
  <style>
    h2 { text-decoration: none; }
  </style>
</head>

<body>
  <%- include('./layouts/header'); -%>
  <%- include('./layouts/navbar'); -%>

  <button class="toggle-sidebar" onclick="toggleSidebar()">☰ Weeks</button>

  <div class="main-wrapper">
    <div class="skins-layout">

      <!-- LEFT PANEL -->
      <div class="skins-sidebar">
        <ul class="skins-list">
          <% weeks.forEach(week => { %>
            <li>
              <% if (!week.enabled) { %>
                <button class="button-3 disabled">
                  Week <%= week.num %> - <%= week.date %> (No Skins)
                </button>
              <% } else { %>
                <button
                  class="button-3 <%= week.current ? 'current' : '' %>"
                  onclick="openPDF(this, 'Week%20<%= week.num %>%20Skins.pdf')"
                >
                  Week <%= week.num %> - <%= week.date %>
                  <% if (week.current) { %>
                    <span class="badge">Current</span>
                  <% } %>
                </button>
              <% } %>
            </li>
          <% }) %>
        </ul>
      </div>

      <!-- RIGHT PANEL -->
      <div class="skins-content">

        <!-- ✅ NAV CONTROLS -->
        <div class="pdf-controls">
          <button onclick="goPrev()">← Previous</button>
          <button onclick="goNext()">Next →</button>
        </div>

        <h2 id="skins-header">Skins Results</h2>

        <div id="loading-indicator">Loading...</div>

        <iframe id="myFrame"></iframe>

      </div>
    </div>
  </div>

  <%- include('layouts/footer'); %>
</body>

<script>
  let currentIndex = 0;

  function getEnabledButtons() {
    return Array.from(document.querySelectorAll(".skins-list button"))
      .filter(btn => !btn.classList.contains("disabled"));
  }

  function updateNavButtons() {
    const buttons = getEnabledButtons();

    document.querySelector(".pdf-controls button:first-child").disabled = currentIndex === 0;
    document.querySelector(".pdf-controls button:last-child").disabled =
      currentIndex === buttons.length - 1;
  }

  function openPDF(button, filename) {

  const buttons = getEnabledButtons();
  currentIndex = buttons.indexOf(button);

  document.querySelectorAll(".skins-list button").forEach(btn => {
    btn.classList.remove("active");
  });

  button.classList.add("active");
  
  const frame = document.getElementById("myFrame");
  const header = document.getElementById("skins-header");
  const loader = document.getElementById("loading-indicator");

  const match = filename.match(/Week%20(\d+)/);
  const week = match ? match[1] : "";

  loader.style.display = "block";

  frame.onload = () => {
    loader.style.display = "none";
  };

  frame.src = "results/2025/" + filename + "?t=" + new Date().getTime();
  header.textContent = `Week ${week} Skins Results`;

  updateNavButtons();
    window.scrollTo({ top: 0, behavior: "auto" });
}

  function goNext() {
    const buttons = getEnabledButtons();
    if (currentIndex < buttons.length - 1) {
      currentIndex++;
      buttons[currentIndex].click();
    }
  }

  function goPrev() {
    const buttons = getEnabledButtons();
    if (currentIndex > 0) {
      currentIndex--;
      buttons[currentIndex].click();
    }
  }

  function toggleSidebar() {
    document.querySelector(".skins-sidebar").classList.toggle("open");
  }

  // AUTO LOAD CURRENT OR LAST
  window.addEventListener("DOMContentLoaded", () => {
    const currentBtn = document.querySelector(".skins-list .current");

    if (currentBtn) {
      currentBtn.click();
      return;
    }

    const buttons = getEnabledButtons();
    const lastBtn = buttons[buttons.length - 1];

    if (lastBtn) lastBtn.click();
  });
</script>

<%- include('layouts/scripts'); %>
</html>