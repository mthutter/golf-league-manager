<!doctype html>
<html lang="en">
  <head>
    <%- include('./partials/header'); %>
  </head>
  <body>
    <section>
      <%- include('./partials/navbar'); %>
    </section>
    <div class="container my-4">
      <div class="gallery-header">
        <h1>Admin Tools</h1>
        <p>Bottoms Up Golf League • 2026 Season</p>
      </div>

      <!-- Main Dashboard Header -->
      <div class="d-flex justify-content-between align-items-center mb-4">
        <a href="/admin" class="btn btn-sm btn-secondary">Back to Dashboard</a>
      </div>

      <!-- Utilities Grid Matrix -->
      <div class="row g-4 mb-4">
        <!-- Utility 1: Weekly Skins Processor -->
        <div class="col-md-6">
          <div class="card shadow-sm h-100">
            <div class="card-header bg-success text-white">
              <h5 class="card-title mb-0">Weekly Skins Processor</h5>
            </div>
            <div class="card-body d-flex flex-column justify-content-between">
              <form method="POST" action="/admin/skins/calculate">
                <div class="mb-3">
                  <label class="form-label fw-bold">Select Week</label>
                  <select name="weekId" class="form-select" required>
                    <option value="">-- Choose Week --</option>
                    <% for(let i = 1; i <= 22; i++) { %>
                    <% if (typeof selectedWeek !== 'undefined' && selectedWeek === i) { %>
                    <option value="<%= i %>" selected>
                      Week
                      <%= i %>
                    </option>
                    <% } else { %>
                    <option value="<%= i %>">Week <%= i %></option>
                    <% } %>
                    <% } %>
                  </select>
                </div>
                <button type="submit" class="btn btn-success w-100">
                  Calculate & Save Skins
                </button>
              </form>
            </div>
          </div>
        </div>

        <!-- Utility 2: Calculate Handicaps -->
        <div class="col-md-6">
          <div class="card shadow-sm h-100">
            <div class="card-header bg-primary text-white">
              <h5 class="card-title mb-0">Handicap Recalculation Engine</h5>
            </div>
            <div class="card-body d-flex flex-column justify-content-between">
              <form method="POST" action="/admin/handicaps/calculate">
                <p class="text-muted small mb-3">
                  Recalculates player handicaps using all scores entered for the
                  current season.
                </p>

                <button type="submit" class="btn btn-primary w-100">
                  Recalculate Player Handicaps
                </button>
              </form>
            </div>
          </div>
        </div>
      </div>
      <!-- Dynamic Results Presentation Section -->
      <% if (typeof results !== 'undefined' && results !== null) { %>
      <div class="card shadow-sm mb-4">
        <div
          class="card-header bg-dark text-white d-flex justify-content-between align-items-center"
        >
          <h5 class="mb-0">Calculated Payouts: Week <%= selectedWeek %></h5>
          <span class="badge bg-success fs-6"
            >Total Pot: $<%= Number(results.totalPot).toFixed(2) %></span
          >
        </div>
        <div class="card-body">
          <div class="table-responsive">
            <table class="table table-striped table-hover align-middle">
              <thead class="table-light">
                <tr>
                  <th>Player Name</th>
                  <th>Holes Claimed</th>
                  <th class="text-center">Skins Total</th>
                  <th class="text-end">Calculated Earnings</th>
                </tr>
              </thead>
              <tbody>
                <% if (!results.leaderboard || results.leaderboard.length === 0) { %>
                <tr>
                  <td colspan="4" class="text-center py-4 text-muted">
                    No unique skins claimed for Week <%= selectedWeek %>. All
                    holes tied or data is missing.
                  </td>
                </tr>
                <% } else { %>
                <% results.leaderboard.forEach(winner => { %> <% let
                itemsToRender = []; if (results.holeDetails &&
                Array.isArray(results.holeDetails)) { const playerWins =
                results.holeDetails.filter(d => Number(d.member_id) ===
                Number(winner.member_id)); playerWins.forEach(w => { const hNum
                = Number(w.hole_number); const totalWinnersForHole =
                results.holeDetails.filter(d => Number(d.hole_number) ===
                hNum).length; const holeBaseValue = results.holePayouts ?
                results.holePayouts[hNum] : 0; const absoluteShare =
                holeBaseValue / (totalWinnersForHole || 1); if
                (totalWinnersForHole > 1) { itemsToRender.push(`Hole ${hNum}
                (Split • $${Math.round(absoluteShare)})`); } else {
                itemsToRender.push(`Hole ${hNum}
                ($${Math.round(absoluteShare)})`); } }); } const holesText =
                itemsToRender.length > 0 ? itemsToRender.join(', ') : 'None';
                const formattedSkins =
                Number(winner.skins_won).toFixed(1).replace('.0', ''); %>
                <tr>
                  <td>
                    <div class="fw-bold">
                      <%= winner.name_first %> <%= winner.name_last %>
                    </div>
                  </td>
                  <td>
                    <%= holesText %>
                  </td>
                  <td class="text-center">
                    <span class="badge bg-secondary rounded-pill px-3">
                      <%= formattedSkins %>
                    </span>
                  </td>
                  <td class="text-end text-success fw-bold">
                    $<%= Number(winner.payout).toFixed(2) %>
                  </td>
                </tr>
                <% }); %>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
      <% } %>
    </div>

    <!-- Bootstrap Toast Container for Handlers Notification Popups -->
    <div
      class="toast-container position-fixed bottom-0 end-0 p-3"
      style="z-index: 1100"
    >
      <div
        id="handicapToast"
        class="toast align-items-center text-white bg-primary border-0 shadow"
        role="alert"
        aria-live="assertive"
        aria-atomic="true"
        data-bs-delay="4000"
      >
        <div class="d-flex">
          <div class="toast-body d-flex align-items-center gap-2">
            <div
              class="spinner-grow spinner-grow-sm text-light"
              role="status"
            ></div>
            <span
              ><strong>Success!</strong> Player handicaps have been completely
              recalculated.</span
            >
          </div>
          <button
            type="button"
            class="btn-close btn-close-white me-2 m-auto"
            data-bs-dismiss="toast"
            aria-label="Close"
          ></button>
        </div>
      </div>
    </div>

    <section>
      <%- include('./partials/footer'); %>
    </section>
    <section>
      <%- include('./partials/scripts'); %>
    </section>

    <!-- Interactive script bindings to initialize components -->
    <script>
      document.addEventListener("DOMContentLoaded", function () {
        const showPopup =
          "<%= typeof showHandicapPopup !== 'undefined' && showHandicapPopup ? 'true' : 'false' %>";
        if (showPopup === "true") {
          const toastElement = document.getElementById("handicapToast");
          if (toastElement && typeof bootstrap !== "undefined") {
            const bootstrapToast = new bootstrap.Toast(toastElement);
            bootstrapToast.show();
          }
        }
      });
    </script>
  </body>
</html>
