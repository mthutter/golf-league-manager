<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Weekly Skins Report</title>
    <!-- Verified Bootstrap CDN StyleSheet Link -->
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <style>
      .skin-winner-card {
        background-color: #d1e7dd;
        border-color: #badbcc;
        color: #0f5132;
      }
      .border-dashed {
        border-style: dashed !important;
      }
      .stroke-marker {
        color: #dc3545;
        font-weight: bold;
        margin-left: 2px;
      }
    </style>
  </head>
  <body class="bg-light">
    <div class="container my-5">
      <header
        class="pb-3 mb-4 border-bottom d-flex justify-content-between align-items-center"
      >
        <h1 class="text-dark fs-2 fw-bold">⛳ League Skins Report</h1>
        <span class="badge bg-secondary fs-6"
          >Skins Format: Net (Holes 1-9)</span
        >
      </header>

      <!-- Week Selector & Admin Trigger Controls Form -->
      <div class="card mb-4 shadow-sm">
        <div class="card-body">
          <div
            class="d-flex flex-wrap align-items-center justify-content-between g-3"
          >
            <!-- Dropdown Selector -->
            <form
              method="GET"
              action="/skins-report"
              class="row g-3 align-items-center m-0"
            >
              <div class="col-auto ps-0">
                <label for="weekId" class="col-form-label fw-semibold"
                  >Select Tournament Week:</label
                >
              </div>
              <div class="col-auto">
                <select
                  name="weekId"
                  id="weekId"
                  class="form-select"
                  onchange="this.form.submit()"
                >
                  <% if (weeks.length === 0) { %>
                  <option value="">No weeks available</option>
                  <% } %>
                  <% weeks.forEach(w => { %>
                  <% if (w.week_id === selectedWeekId) { %>
                  <option value="<%= w.week_id %>" selected>
                    Week
                    <%= w.week_id %>
                  </option>
                  <% } else { %>
                  <option value="<%= w.week_id %>">
                    Week <%= w.week_id %>
                  </option>
                  <% } %>
                  <% }) %>
                </select>
              </div>
            </form>

            <!-- Asynchronous Admin Trigger Button -->
            <% if (selectedWeekId) { %>
            <div class="col-auto pe-0">
              <button
                type="button"
                id="recalcBtn"
                class="btn btn-warning fw-bold shadow-sm"
              >
                🔄 Recalculate Week <%= selectedWeekId %>
              </button>
            </div>
            <% } %>
          </div>
        </div>
      </div>

      <% if (!selectedWeekId) { %>
      <div class="alert alert-warning text-center">
        No game data has been processed yet.
      </div>
      <% } else { %>

      <!-- Summary Stats Banner Row -->
      <div class="row mb-4 text-center">
        <div class="col-md-6 mb-3 mb-md-0">
          <div class="card p-3 shadow-sm bg-primary text-white">
            <h3 class="fs-6 text-uppercase fw-bold opacity-75">
              Total Skins Purse
            </h3>
            <p class="fs-2 fw-bold mb-0">$<%= totalPot.toFixed(2) %></p>
          </div>
        </div>
        <div class="col-md-6">
          <div class="card p-3 shadow-sm bg-dark text-white">
            <h3 class="fs-6 text-uppercase fw-bold opacity-75">
              Skins Documented
            </h3>
            <p class="fs-2 fw-bold mb-0"><%= holeDetails.length %></p>
          </div>
        </div>
      </div>

      <div class="row">
        <!-- Payout Standings Leaderboard Table -->
        <div class="col-lg-5 mb-4">
          <div class="card shadow-sm h-100">
            <div class="card-header bg-white border-bottom py-3">
              <h5 class="card-title mb-0 fw-bold">Payout Standings</h5>
            </div>
            <div class="table-responsive">
              <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                  <tr>
                    <th>Player</th>
                    <th class="text-center">Skins Won</th>
                    <th class="text-end">Total Payout</th>
                  </tr>
                </thead>
                <tbody>
                  <% if (leaderboard.length === 0) { %>
                  <tr>
                    <td colspan="3" class="text-muted text-center py-4">
                      No skins won this week. All holes tied!
                    </td>
                  </tr>
                  <% } else { %>
                  <% leaderboard.forEach(player => { %>
                  <tr>
                    <td class="fw-semibold">
                      <%= player.name_first %> <%= player.name_last %>
                    </td>
                    <td class="text-center">
                      <span
                        class="badge bg-light text-dark border border-secondary px-2.5"
                        ><%= player.skins_won %></span
                      >
                    </td>
                    <td class="text-end fw-bold text-success">
                      $<%= player.payout.toFixed(2) %>
                    </td>
                  </tr>
                  <% }) %>
                  <% } %>
                </tbody>
              </table>
            </div>
          </div>
        </div>

        <!-- Hole-by-Hole Visual Grid Breakdown -->
        <div class="col-lg-7 mb-4">
          <div class="card shadow-sm h-100">
            <div class="card-header bg-white border-bottom py-3">
              <h5 class="card-title mb-0 fw-bold">
                Hole-by-Hole Skin Breakdown
              </h5>
            </div>
            <div class="card-body">
              <div class="row row-cols-1 row-cols-sm-3 g-3">
                <% for (let h = 1; h <= 9; h++) { %> <% const holeWinners =
                holeDetails.filter(d => d.hole_number === h); %>
                <div class="col">
                  <div
                    class="card h-100 text-center <%= holeWinners.length > 0 ? 'skin-winner-card' : 'bg-light border-dashed' %>"
                  >
                    <div class="card-body py-3">
                      <h6
                        class="text-uppercase tracking-wider font-monospace text-muted small mb-1"
                      >
                        Hole <%= h %>
                      </h6>

                      <% if (holeWinners.length > 0) { %> <%
                      holeWinners.forEach((winner, idx) => { %>
                      <p class="fs-6 fw-bold mb-0 text-truncate">
                        <%= winner.name_first %>
                      </p>
                      <% if (idx < holeWinners.length - 1) { %>
                      <small class="text-muted d-block my-0 fw-semibold"
                        >&amp;</small
                      >
                      <% } %>
                      <% }) %>

                      <!-- FIXED CHIP DETECTOR LINK: Safely picks index 0 map properties -->
                      <small class="d-block text-secondary mt-1"
                        >Net:
                        <strong
                          ><%= holeWinners[0] ? holeWinners[0].net_score : '' %></strong
                        ></small
                      >
                      <span class="badge bg-success mt-1">
                        +$<%= holeWinners.reduce((sum, w) => sum + w.payout,
                        0).toFixed(2) %> Total
                      </span>
                      <% } else { %>
                      <span class="text-muted d-block py-2 small"
                        >Halved / Carried</span
                      >
                      <% } %>
                    </div>
                  </div>
                </div>
                <% } %>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </body>
</html>
      <!-- Participant Complete Scores Grid Matrix -->
      <div class="row mt-4">
        <div class="col-12">
          <div class="card shadow-sm">
            <div class="card-header bg-dark text-white py-3">
              <h5 class="card-title mb-0 fw-bold">⛳ Participant Complete Scores Grid</h5>
              <small class="text-white-50">Displays Gross / Net scores. Highlighted green cells indicate a won or split skin.</small>
            </div>
            <div class="table-responsive">
              <table class="table table-bordered align-middle text-center mb-0">
                <thead class="table-light">
                  <tr>
                    <th class="text-start" style="min-width: 180px;">Player</th>
                    <th style="width: 70px;">Hcp</th>
                    <% for (let h = 1; h <= 9; h++) { %>
                      <th>H<%= h %></th>
                    <% } %>
                  </tr>
                </thead>
                <tbody>
                  <% if (participantScores.length === 0) { %>
                    <tr>
                      <td colspan="11" class="text-muted py-4">No active participant data found for this week.</td>
                    </tr>
                  <% } else { %>
                    <% participantScores.forEach(player => { %>
                      <tr>
                        <td class="text-start fw-semibold bg-light">
                          <%= player.name %>
                        </td>
                        <td class="text-muted small bg-light">
                          <%= player.handicap %>
                        </td>
                        
                        <% player.holes.forEach(h => { %>
                          <% const isSkinWinner = holeDetails.some(d => d.hole_number === h.holeNumber && d.member_id === player.memberId); %>
                          
                          <td class="<%= isSkinWinner ? 'table-success border border-success fw-bold' : '' %>" style="<%= isSkinWinner ? 'background-color: #d1e7dd;' : '' %>">
                            <div>
                              <span class="fs-6 d-block text-dark"><%= h.gross %></span>
                              <small class="text-secondary font-monospace d-block" style="font-size: 0.75rem;">
                                N: <%= h.net %>
                                <% if (h.strokes > 0) { %>
                                  <span class="stroke-marker" title="<%= h.strokes %> handicap stroke(s) applied">*</span>
                                <% } %>
                              </small>
                            </div>
                          </td>
                        <% }) %>
                      </tr>
                    <% }) %>
                  <% } %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>

    <% } %>
  </div>

  <!-- Verified Bootstrap JS Bundle CDN Link -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

  <!-- Async Recalculation Engine Fetch Script -->
  <script>
    document.getElementById('recalcBtn')?.addEventListener('click', async () => {
      const weekId = "<%= selectedWeekId %>";
      if (!weekId) return;

      const btn = document.getElementById('recalcBtn');
      const originalText = btn.innerHTML;
      
      btn.disabled = true;
      btn.innerHTML = "⏳ Calculating...";

      try {
        const response = await fetch(`/skins-report/calculate/${weekId}`, { 
          method: 'POST' 
        });
        const result = await response.json();

        if (response.ok) {
          window.location.reload();
        } else {
          alert("Error recalculating skins: " + (result.error || "Unknown error"));
          btn.disabled = false;
          btn.innerHTML = originalText;
        }
      } catch (err) {
        console.error("Skins calculation trigger exception:", err);
        alert("Network or internal server error triggering calculation.");
        btn.disabled = false;
        btn.innerHTML = originalText;
      }
    });
  </script>
</body>
</html>
