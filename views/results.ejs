<!doctype html>
<html lang="en">

<%- include('./layouts/header'); -%>
<style>
  /* ========================
  RESULTS PAGE
  ======================== */

  .results-card {
    background: rgba(255, 255, 255, 0.06);
    border-radius: 14px;
    padding: 18px 20px;
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.15);
    backdrop-filter: blur(4px);
  }

  /* section titles */
  .results-card h4 {
    color: rgba(255, 255, 255, 0.92);
    font-weight: 600;
    margin-bottom: 4px;
  }

  .results-card h5 {
    font-size: 14px;
    margin-bottom: 18px;
  }

  /* week links */
  .results-card a {
    display: block;
    padding: 6px 10px;
    margin-bottom: 3px;

    border-radius: 8px;

    background: rgba(0, 0, 0, 0.12);
    color: #d8f5d8 !important;

    transition: all 0.18s ease;
  }

  /* hover effect */
  .results-card a:hover {
    background: rgba(255, 255, 255, 0.08);
    transform: translateX(4px);
    text-decoration: none;
  }

  /* inactive weeks */
  .results-card a:not([href]) {
    opacity: 0.65;
    cursor: default;
  }

  /* active downloadable weeks */
  .results-card a[href] {
    border-left: 3px solid #90ee90;
  }

  /* subtle divider */
  .results-card::after {
    content: "";
    display: block;
    width: 40px;
    height: 1px;
    margin: 16px auto 0;
    background: rgba(255, 255, 255, 0.15);
  }

  .week-label {
    font-weight: 600;
  }

  .week-date {
    opacity: 0.75;
    font-size: 13px;
    margin-left: 4px;
  }
</style>


