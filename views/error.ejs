<!doctype html>
<html lang="en">
  <head>
    <%- include ('./layouts/header'); %>
    <style>
      .error-box {
        max-width: 600px;
        margin: 3rem auto;
        background: white;
        padding: 2rem;
        border-radius: 8px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
      }

      h1 {
        margin-top: 0;
        color: #b00020;
      }
    </style>
  </head>

  <body>
    <%- include ('./layouts/navbar'); %>
    <div class="main-wrapper">
      <div class="error-box">
        <h1>Something Went Wrong</h1>
        <p><%= message %></p>
      </div>
    </div>
    <%- include('layouts/footer'); %>
    <%- include('layouts/scripts'); %>
  </body>
</html>
