<!doctype html>
<html lang="en">
  <head>
    <%- include('layouts/header'); %>
    <style>
      th,
      td {
        margin: 0 auto;
        text-align: center;
      }

      .gold-cell {
        background-color: #ffd700 !important;
        font-weight: bold;
      }

      .silver-cell {
        background-color: #c0c0c0 !important;
        font-weight: bold;
      }

      .bronze-cell {
        background-color: #cd7f32 !important;
        color: white;
        font-weight: bold;
      }

      table {
        border-collapse: collapse;
        width: 100%;
        font-family: sans-serif;
      }
      th,
      td {
        padding: 12px;
        border: 1px solid #ddd;
        text-align: center;
      }
      /* Style headers to look clickable */
      th {
        background-color: #f4f4f4;
        cursor: pointer;
        user-select: none;
        position: relative;
      }
      /* Visual indicators for sorting */
      th.sort-asc::after {
        content: " ▲";
        position: absolute;
        right: 8px;
      }
      th.sort-desc::after {
        content: " ▼";
        position: absolute;
        right: 8px;
      }
    </style>
  </head>

  <body>
    <%- include('layouts/navbar'); %>
    <div class="gallery-header">
      <h1>League Standings</h1>
      <p>Bottoms Up Golf League • 2026 Season</p>
    </div>
    <br />
    <div class="row mb-4">
      <div style="margin: 0 auto" class="col-md-2">
        <form>
          <select
            class="form-select"
            onchange="if(this.value) window.location=this.value;"
          >
            <option value="">Weekly Results...</option>
            <option value="/scores/weekly/1">Week 1</option>
            <option value="/scores/weekly/2">Week 2</option>
            <option value="/scores/weekly/3">Week 3</option>
            <option value="/scores/weekly/4">Week 4</option>
          </select>
        </form>
      </div>
    </div>
    <br />
    <table id="sortableTable" class="table table-striped table-hover">
      <thead>
        <tr>
          <th>Rank</th>
          <th>Player</th>
          <th>Rounds Played</th>
          <th>Birdie Points</th>
          <th>CTP Points</th>
          <th>Total Points</th>
          <th>Gross Avg</th>
          <th>Net Avg</th>
          <th>Points Avg</th>
        </tr>
      </thead>
      <tbody>
        <% standings.forEach((player, idx) => { %>
        <tr>
          <td><%= idx + 1 %></td>
          <td><%= player.player_name %></td>
          <td><%= player.weeks_played %></td>
          <td><%= player.birdie_points %></td>
          <td><%= player.ctp_points %></td>
          <td>
            <strong><%= player.total_points %></strong>
          </td>
          <td><%= Number(player.avg_gross).toFixed(2) %></td>
          <td><%= Number(player.avg_net).toFixed(2) %></td>
          <td
            class="<% if (idx === 0) { %>gold-cell<% } %> <% if (idx === 1) { %>silver-cell<% } %> <% if (idx === 2) { %>bronze-cell<% } %>"
          >
            <strong><%= Number(player.avg_points).toFixed(2) %></strong>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>

    <script>
      document
        .querySelectorAll("#sortableTable th")
        .forEach((headerCell, columnIndex) => {
          headerCell.addEventListener("click", () => {
            const tableElement = headerCell.closest("table");
            const tbodyElement = tableElement.querySelector("tbody");
            const rowsArray = Array.from(tbodyElement.querySelectorAll("tr"));

            // Determine sort direction (default to ascending)
            const isAscending = headerCell.classList.contains("sort-asc");
            const directionModifier = isAscending ? -1 : 1;

            // Reset visual indicators on all headers
            tableElement
              .querySelectorAll("th")
              .forEach((th) => th.classList.remove("sort-asc", "sort-desc"));

            // Sort the array of DOM rows
            rowsArray.sort((rowA, rowB) => {
              const cellA = rowA.children[columnIndex].textContent.trim();
              const cellB = rowB.children[columnIndex].textContent.trim();

              // Handle numeric values vs string values smoothly
              const valueA = isNaN(cellA) ? cellA : parseFloat(cellA);
              const valueB = isNaN(cellB) ? cellB : parseFloat(cellB);

              if (typeof valueA === "number" && typeof valueB === "number") {
                return (valueA - valueB) * directionModifier;
              }

              return (
                valueA.localeCompare(valueB, undefined, {
                  numeric: true,
                  sensitivity: "base",
                }) * directionModifier
              );
            });

            // Re-append rows in the new sorted order
            rowsArray.forEach((row) => tbodyElement.appendChild(row));

            // Apply new visual indicators
            headerCell.classList.add(isAscending ? "sort-desc" : "sort-asc");
          });
        });
    </script>

    <%- include('layouts/scripts'); %>
    <%- include('layouts/footer'); %>
  </body>
</html>
