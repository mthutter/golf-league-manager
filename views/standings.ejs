<!doctype html>
<html lang="en">
  <head>
    <%- include('./partials/header') %>
    <link href="/assets/css/standings.css" rel="stylesheet" />
  </head>

  <body>
    <%- include('./partials/navbar') %>

    <!-- Header Banner -->
    <div class="container">
      <div class="gallery-header">
        <h1>2026 Season Standings</h1>
        <p>
          Through Week <%= currentWeek.week_number %> (<%=
          currentWeek.displayDate %>) • Bottoms Up Golf League
        </p>
      </div>
      <div class="week-results-container">
        <span class="week-results-label">Weekly Results:</span>
        <div class="week-nav">
          <% weeks .filter(week => week.week_number <=
          currentWeek.week_number).forEach(week => { %>

          <a
            href="/scores/weekly/<%= week.week_number %>"
            class="button-link btn btn-light btn-sm"
          >
            Week
            <%= week.week_number %>
          </a>

          <% }) %>
        </div>
      </div>
      <br />
    </div>

    <!-- Standings -->
    <div class="container">
      <div class="card standings-card shadow-lg mb-5">
        <div class="card-body p-0">
          <table id="sortableTable" class="table standings-table table-hover">
            <thead>
              <tr>
                <th>Pos</th>
                <th class="movement-header"></th>
                <th>Player</th>
                <th>HCP</th>
                <th>Rounds</th>
                <th>Birdies</th>
                <th>CTP</th>
                <th>Total Pts</th>
                <th>Gross Avg</th>
                <th>Net Avg</th>
                <th>Avg Pts</th>
              </tr>
            </thead>
            <tbody>
              <% standings.forEach((player, idx) => { %>
              <tr>
                <td class="position-cell">
                  <% if (idx > 0 && player.rank === standings[idx - 1].rank) {
                  %>
                  <!-- Leave blank for subsequent tied players -->
                  <% } else { %>
                  <%= player.rank %>
                  <% } %>
                </td>
                <td class="movement-cell">
                  <% if (player.movement === "up") { %>
                  <span class="trend-up">▲<%= player.delta %></span>
                  <% } else if (player.movement === "down") { %>
                  <span class="trend-down">▼<%= player.delta %></span>
                  <% } else { %>
                  <span class="trend-same">—</span>
                  <% } %>
                </td>
                <td>
                  <strong
                    ><a
                      href="/scores/members/<%= player.id %>"
                      class="player-link"
                      ><%= player.player_name %></a
                    ></strong
                  >
                </td>
                <td style="color: #2a35c2">
                  <strong><%= player.current_handicap %></strong>
                </td>
                <td>
                  <%= player.weeks_played %>
                </td>
                <td>
                  <%= player.birdie_points %>
                </td>
                <td>
                  <%= player.ctp_points %>
                </td>
                <td><%= player.total_points %></td>
                <td>
                  <%= Number(player.avg_gross).toFixed(2) %>
                </td>
                <td>
                  <%= Number(player.avg_net).toFixed(2) %>
                </td>
                <td
                  class="points-average <%= player.rank === 1 ? 'gold-cell' : '' %> <%= player.rank === 2 ? 'silver-cell' : '' %> <%= player.rank === 3 ? 'bronze-cell' : '' %>"
                >
                  <%= Number(player.avg_points).toFixed(2) %>
                </td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <%- include('./partials/scripts') %>
    <%- include('./partials/footer') %>
  </body>
</html>
