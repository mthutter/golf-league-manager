<!doctype html>
<html lang="en">
  <head>
    <%- include('layouts/header'); %>
    <style>
      .player-link {
        color: #1b4332;
        text-decoration: none;
        transition: color 0.2s ease;
      }
      .player-link:hover {
        color: #18aa24;
        text-decoration: underline;
      }
      .button-link {
        display: inline-block;
        padding: 10px 20px;
        background-color: #53da80;
        color: white;
        text-decoration: none;
        border-radius: 5px;
      }
      /* ===== Header Banner ===== */
      .page-banner {
        background: linear-gradient(135deg, #1b4332 0%, #2d6a4f 100%);
        color: white;
        padding: 3rem 0 2rem;
        margin-bottom: 2rem;
      }
      .gallery-header {
        text-align: center;
      }
      .gallery-header h1 {
        font-weight: 700;
        margin-bottom: 0.5rem;
      }
      .gallery-header p {
        opacity: 0.9;
        margin-bottom: 1rem;
      }
      .week-nav {
        display: flex;
        justify-content: center;
        gap: 0.5rem;
        flex-wrap: wrap;
      }
      .week-nav .btn {
        min-width: 85px;
        font-weight: 600;
        border-radius: 50px;
        border: none;
        transition: all 0.2s ease;
      }
      .week-nav .btn:hover {
        transform: translateY(-1px);
      }
      /* ===== Standings Card ===== */
      .standings-card {
        border: none;
        border-radius: 18px;
        overflow: hidden;
      }
      /* ===== Table ===== */
      .standings-table {
        margin-bottom: 0;
      }
      .standings-table thead {
        background: #1b4332;
        color: white;
      }
      .standings-table th {
        border: none;
        padding: 14px;
        text-align: center;
        font-weight: 600;
        letter-spacing: 0.5px;
        cursor: pointer;
        user-select: none;
      }
      .standings-table td {
        text-align: center;
        vertical-align: middle;
        padding: 12px;
      }
      .standings-table tbody tr:hover {
        background-color: #f8f9fa;
      }
      /* Player column left aligned */
      .standings-table td:nth-child(2) {
        text-align: left;
      }
      /* ===== Position Column ===== */
      .position-cell {
        width: 70px;
        font-size: 1.15rem;
        font-weight: 700;
        text-align: center !important;
      }
      /* ===== Leader Row ===== */
      .leader-row {
        background-color: rgba(27, 67, 50, 0.08) !important;
        border-left: 5px solid #1b4332;
      }
      .leader-row td {
        font-weight: 600;
      }
      /* ===== Podium Colors ===== */
      .gold-cell {
        background-color: #ffd700 !important;
        font-weight: bold;
      }
      .silver-cell {
        background-color: #c0c0c0 !important;
        font-weight: bold;
      }
      .bronze-cell {
        background-color: #cd7f32 !important;
        color: white;
        font-weight: bold;
      }
      .points-average {
        font-size: 1.05rem;
        font-weight: 700;
      }
      th {
        background-color: #18aa24 !important;
      }
      td {
        background-color: #53da80 !important;
      }
    </style>
  </head>
  <body>
    <%- include('layouts/navbar'); %>

    <!-- Header Banner -->
    <div class="container">
      <div class="gallery-header">
        <h1>Current Standings</h1>
        <p>Bottoms Up Golf League • 2026 Season</p>
      </div>
      <div class="week-nav">
        <a href="/scores/weekly/1" class="button-link btn btn-light btn-sm"
          >Week 1</a
        >
        <a href="/scores/weekly/2" class="button-link btn btn-light btn-sm"
          >Week 2</a
        >
        <a href="/scores/weekly/3" class="button-link btn btn-light btn-sm"
          >Week 3</a
        >
        <a href="/scores/weekly/4" class="button-link btn btn-light btn-sm"
          >Week 4</a
        >
        <a href="/scores/weekly/5" class="button-link btn btn-light btn-sm"
          >Week 5</a
        >
      </div>
      <br />
    </div>

    <!-- Standings -->
    <div class="container">
      <div class="card standings-card shadow-lg mb-5">
        <div class="card-body p-0">
          <table id="sortableTable" class="table standings-table table-hover">
            <thead>
              <tr>
                <th>Pos</th>
                <th>Player</th>
                <th>Rounds</th>
                <th>Birdies</th>
                <th>CTP</th>
                <th>Total Pts</th>
                <th>Gross Avg</th>
                <th>Net Avg</th>
                <th>Avg Pts</th>
              </tr>
            </thead>
            <tbody>
              <% standings.forEach((player, idx) => { %>
              <tr class="<%= player.rank === 1 ? 'leader-row' : '' %>">
                <td class="position-cell">
                  <% if (idx > 0 && player.rank === standings[idx - 1].rank) {
                  %>
                  <!-- Leave blank for subsequent tied players -->
                  <% } else { %>
                  <%= player.rank %>
                  <% } %>
                </td>
                <td>
                  <strong
                    ><a
                      href="/scores/members/<%= player.id %>"
                      class="player-link"
                      ><%= player.player_name %></a
                    ></strong
                  >
                </td>
                <td>
                  <%= player.weeks_played %>
                </td>
                <td>
                  <%= player.birdie_points %>
                </td>
                <td>
                  <%= player.ctp_points %>
                </td>
                <td>
                  <strong><%= player.total_points %></strong>
                </td>
                <td>
                  <%= Number(player.avg_gross).toFixed(2) %>
                </td>
                <td>
                  <%= Number(player.avg_net).toFixed(2) %>
                </td>
                <td
                  class="points-average <%= player.rank === 1 ? 'gold-cell' : '' %> <%= player.rank === 2 ? 'silver-cell' : '' %> <%= player.rank === 3 ? 'bronze-cell' : '' %>"
                >
                  <%= Number(player.avg_points).toFixed(2) %>
                </td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <%- include('layouts/scripts'); %>
    <%- include('layouts/footer'); %>
  </body>
</html>
