<!DOCTYPE html>
<html lang="en">
<style>
  img:hover {
    border: 5px solid rgb(38, 226, 38);
  }
</style>


<body>

  <%- include('./layouts/header'); -%>
  <%- include('./layouts/navbar'); -%>

  <div class="main-wrapper">
    <div>
      <h1 style="text-align: center;">2025 Images</h1>
    </div>

    <div class="container">
      <div class="row justify-content-center">
        <% filenames.forEach(function(name) { %>
        <div class="col-xl-2 col-lg-3 col-md-3 col-sm-3 my-2" style="padding: 10px">
          <a id="holder" href="https://bottoms-up.b-cdn.net/2025/<%= name %>"><img alt="<%= name%>" loading="lazy" src="https://bottoms-up.b-cdn.net/2025/<%= name %>" class="img-fluid">
          </a>
        </div>
        <% }) %>
      </div>
    </div>
  </div>

  <%- include('./layouts/footer'); -%>
  <%- include('./layouts/scripts'); -%>

</body>

</html>