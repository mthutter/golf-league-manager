<!doctype html>
<html lang="en">
<style>
  /* ========================
  COURSE INFO
  ======================== */

  .course-info {
    text-align: center;
    margin-bottom: 20px;
  }

  .course-info p {
    margin: 4px 0;
    color: rgba(255, 255, 255, 0.8);
  }

  /* ========================
  SCORECARD CARD
  ======================== */

  .scorecard-card {
    max-width: 1000px;

    margin: 20px auto;
    padding: 16px;

    background: rgba(255, 255, 255, 0.06);

    border-radius: 14px;

    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.15);
  }

  /* ========================
  SECTION HEADER
  ======================== */

  .scorecard-section-header {
    text-align: center;
    margin-bottom: 14px;
  }

  .scorecard-section-header h3 {
    color: white;
    margin-bottom: 2px;
  }

  .scorecard-section-header p {
    color: rgba(255, 255, 255, 0.75);
    font-size: 14px;
  }

  /* ========================
  TABLE WRAPPER
  ======================== */

  .table-wrapper {
    width: 100%;
    overflow-x: auto;

    -webkit-overflow-scrolling: touch;
  }

  /* ========================
  SCORECARD
  ======================== */

  .scorecard {
    border-collapse: collapse;

    width: auto;
    margin: 0 auto;

    font-size: 13px;
  }

  .scorecard td,
  .scorecard th {
    border: 1px solid rgba(0, 0, 0, 0.35);

    padding: 5px 8px;

    text-align: center;
    white-space: nowrap;
  }

  /* first column */

  .scorecard td:first-child,
  .scorecard th:first-child {
    font-weight: 600;
    text-align: left;

    padding-left: 10px;
  }

  /* header */

  .scorecard-header th {
    background: rgba(0, 0, 0, 0.8);
    color: white;
  }

  /* FRONT */

  .men-front td {
    background: #f5f5f5;
    color: #111;
  }

  .women-front td {
    background: #c62828;
    color: white;
  }

  /* BACK */

  .men-back td {
    background: #1e6fb6;
    color: white;
  }

  .women-back td {
    background: #d4af37;
    color: #111;
  }

  /* PAR */

  .par-row td {
    background: rgba(0, 0, 0, 0.2);
    color: white;
  }

  /* HCP */

  .hcp-row td {
    background: #1b7f3a;
    color: white;
  }

  /* ========================
  MOBILE
  ======================== */

  @media (max-width: 768px) {

    .scorecard-card {
      padding: 10px;
    }

    .scorecard td,
    .scorecard th {
      padding: 4px 6px;
      font-size: 12px;
    }

    .scorecard-section-header h3 {
      font-size: 20px;
    }

    .scorecard-section-header p {
      font-size: 13px;
    }
  }
</style>


<%- include('./layouts/header'); -%>


