<script
  src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
  integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
  crossorigin="anonymous"
></script>

<!-- Make tables sortable with header row cell click (toggles ASC/DESC)-->
<script>
  document
    .querySelectorAll("#sortableTable th")
    .forEach((headerCell, columnIndex) => {
      headerCell.addEventListener("click", () => {
        const tableElement = headerCell.closest("table");
        const tbodyElement = tableElement.querySelector("tbody");
        const rowsArray = Array.from(tbodyElement.querySelectorAll("tr"));

        const isAscending = headerCell.classList.contains("sort-asc");
        const directionModifier = isAscending ? -1 : 1;

        tableElement
          .querySelectorAll("th")
          .forEach((th) => th.classList.remove("sort-asc", "sort-desc"));

        // 1. Sort the array of DOM rows
        rowsArray.sort((rowA, rowB) => {
          let cellA = rowA.children[columnIndex].textContent.trim();
          let cellB = rowB.children[columnIndex].textContent.trim();

          // Strip emojis for sorting the original rank column
          if (columnIndex === 0) {
            const medalMap = { "🥇": "1", "🥈": "2", "🥉": "3" };
            cellA = medalMap[cellA] || cellA;
            cellB = medalMap[cellB] || cellB;
          }

          const valueA =
            isNaN(cellA) || cellA === "" ? cellA : parseFloat(cellA);
          const valueB =
            isNaN(cellB) || cellB === "" ? cellB : parseFloat(cellB);

          if (typeof valueA === "number" && typeof valueB === "number") {
            return (valueA - valueB) * directionModifier;
          }
          return (
            valueA.localeCompare(valueB, undefined, {
              numeric: true,
              sensitivity: "base",
            }) * directionModifier
          );
        });

        // 2. Dynamically calculate ranks and ties based on the sorted column
        let currentRank = 1;
        let skipCount = 0;
        let previousValue = null;

        rowsArray.forEach((row, index) => {
          // Get the value of the column we are currently sorting by
          const currentCellText = row.children[columnIndex].textContent.trim();

          if (index === 0) {
            currentRank = 1;
            skipCount = 1;
          } else if (currentCellText === previousValue) {
            // It's a tie! Keep the same rank, increment the skip counter
            skipCount++;
          } else {
            // Not a tie. Advance rank by the total number of skipped slots
            currentRank += skipCount;
            skipCount = 1;
          }
          previousValue = currentCellText;

          // 3. Update the visual position column (Index 0)
          const posCell = row.children[0];
          if (currentRank === 1) {
            posCell.textContent = "🥇";
          } else if (currentRank === 2) {
            posCell.textContent = "🥈";
          } else if (currentRank === 3) {
            posCell.textContent = "🥉";
          } else {
            posCell.textContent = currentRank;
          }

          // 4. Clean up leader styling and re-append to the table
          row.classList.remove("leader-row");
          if (index === 0) row.classList.add("leader-row");

          tbodyElement.appendChild(row);
        });

        headerCell.classList.add(isAscending ? "sort-desc" : "sort-asc");
      });
    });
</script>
