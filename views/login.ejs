<!doctype html>
<html lang="en">
  <head>
    <%- include ('./partials/header'); %>
    <style>
      .login-card {
        margin: 0 auto;
        width: 100%;
        max-width: 420px;

        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(8px);

        border-radius: 1rem;
        padding: 2rem;

        box-shadow: 0 10px 35px rgba(0, 0, 0, 0.25);
      }

      .league-title {
        font-weight: 700;
        font-size: 1.8rem;
        text-align: center;
        margin-bottom: 0.25rem;
      }

      .league-subtitle {
        text-align: center;
        color: #6c757d;
        margin-bottom: 2rem;
      }

      .btn-login {
        font-weight: 600;
        padding: 0.75rem;
        border-radius: 0.75rem;
      }

      .form-control {
        border-radius: 0.75rem;
        padding: 0.75rem;
      }

      .logo-icon {
        font-size: 3rem;
        text-align: center;
        margin-bottom: 1rem;
      }
    </style>
  </head>

  <body>
    <%- include ('./partials/navbar'); %>
    <br />
    <div class="login-card">
      <div class="logo-icon">⛳</div>
      <div class="league-title">Bottoms Up Golf League</div>
      <div class="league-subtitle">Member Access</div>

      <% if (typeof error !== "undefined") { %>
      <div class="alert alert-danger"><%= error %></div>
      <% } %>

      <form method="POST" action="/login">
        <div class="mb-3">
          <label class="form-label fw-semibold"> Username </label>

          <input type="text" name="username" class="form-control" required />
        </div>

        <div class="mb-4">
          <label class="form-label fw-semibold"> Password </label>

          <input
            type="password"
            name="password"
            class="form-control"
            required
          />
        </div>

        <button type="submit" class="btn btn-success w-100 btn-login">
          Login
        </button>
      </form>

      <div class="text-center mt-4">
        <a href="/" class="text-decoration-none"> ← Return to League Home </a>
      </div>
    </div>

    <%- include ('./partials/footer'); %>
    <%- include ('./partials/scripts'); %>
  </body>
</html>
