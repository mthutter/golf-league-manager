<!doctype html>
<html lang="en">
<%- include('layouts/header'); %>


<style>
  :root {
    --green-main: rgb(47, 138, 47);
    --green-dark: rgb(30, 110, 30);
    --green-light: rgba(144, 238, 144, 0.18);
    --card-bg: rgba(255, 255, 255, 0.94);
  }



  /* =========================
       HERO
    ========================= */

  .form-hero {
    max-width: 900px;
    margin: 0 auto 2rem;
    text-align: center;

    padding: 2rem;
    border-radius: 24px;

    background: linear-gradient(135deg, rgba(47, 138, 47, 0.97), rgba(30, 110, 30, 0.97));

    color: white;

    box-shadow: 0 14px 34px rgba(0, 0, 0, 0.15);
  }

  .form-hero h1 {
    margin: 0;
    font-size: clamp(2rem, 5vw, 3.2rem);
    font-weight: 800;
    letter-spacing: 0.5px;
  }

  .form-hero p {
    margin-top: 0.7rem;
    margin-bottom: 0;
    opacity: 0.92;
    font-size: 1.05rem;
  }

  /* =========================
       FORM CARD
    ========================= */

  .player-form-card {
    max-width: 900px;
    margin: 0 auto;

    padding: 2rem;

    border-radius: 24px;

    background: var(--card-bg);

    border: 1px solid rgba(255, 255, 255, 0.45);

    backdrop-filter: blur(10px);

    box-shadow:
      0 14px 40px rgba(0, 0, 0, 0.12),
      0 3px 12px rgba(0, 0, 0, 0.05);
  }

  /* =========================
       FORM SECTIONS
    ========================= */

  .form-section {
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid #e5efe5;
  }

  .form-section:last-child {
    border-bottom: none;
    margin-bottom: 0;
    padding-bottom: 0;
  }

  .form-section h3 {
    margin-bottom: 1.25rem;

    font-size: 1.25rem;
    font-weight: 700;

    color: var(--green-dark);
  }

  /* =========================
       LABELS
    ========================= */

  .form-label {
    font-weight: 600;
    color: #244224;
    margin-bottom: 0.45rem;
  }

  /* =========================
       INPUTS
    ========================= */

  .form-control,
  .form-select {
    border-radius: 14px;

    border: 2px solid #d8e8d8;

    padding: 0.85rem 1rem;

    background: rgba(255, 255, 255, 0.96);

    transition:
      border-color 0.2s ease,
      box-shadow 0.2s ease,
      transform 0.15s ease;
  }

  .form-control:focus,
  .form-select:focus {
    border-color: var(--green-main);

    box-shadow: 0 0 0 4px rgba(47, 138, 47, 0.15);

    transform: translateY(-1px);
  }

  /* =========================
       BUTTON
    ========================= */

  .btn-submit-player {
    border: none;

    border-radius: 16px;

    padding: 0.95rem 2rem;

    font-size: 1rem;
    font-weight: 700;
    letter-spacing: 0.4px;

    color: white;

    background: linear-gradient(135deg, rgb(47, 138, 47), rgb(30, 110, 30));

    box-shadow: 0 8px 20px rgba(47, 138, 47, 0.25);

    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease;
  }

  .btn-submit-player:hover {
    transform: translateY(-2px);

    box-shadow: 0 12px 28px rgba(47, 138, 47, 0.35);
  }

  .btn-submit-player:active {
    transform: translateY(0);
  }

  /* =========================
       OPTIONAL PLAYER PREVIEW
    ========================= */

  .player-preview {
    background: linear-gradient(145deg, rgba(47, 138, 47, 0.12), rgba(255, 255, 255, 0.9));

    border-radius: 20px;

    padding: 1.5rem;

    border: 1px solid rgba(47, 138, 47, 0.15);

    text-align: center;

    margin-top: 2rem;
  }

  .player-preview .preview-name {
    font-size: 1.6rem;
    font-weight: 800;
    color: var(--green-dark);
  }

  .player-preview .preview-meta {
    margin-top: 0.5rem;
    color: #4f664f;
    font-weight: 500;
  }

  /* =========================
       MOBILE
    ========================= */

  @media (max-width: 768px) {
    body {
      padding: 1rem 0.75rem;
    }

    .form-hero {
      padding: 1.5rem 1rem;
      border-radius: 20px;
    }

    .player-form-card {
      padding: 1.25rem;
      border-radius: 20px;
    }

    .btn-submit-player {
      width: 100%;
    }
  }
</style>

<%- include('layouts/navbar'); %>

<body>
  <!-- HERO -->
  <div class="main-wrapper">
    <div class="gallery-header">
      <h1>Add Player Form</h1>
      <p>Bottoms Up Golf League</p>
    </div>

    <!-- FORM CARD -->
    <div class="player-form-card">
      <form action="/add-player" method="POST">
        <!-- PLAYER INFO -->
        <div class="form-section">
          <h3>Player Information</h3>
          <div class="row g-4">
            <div class="col-md-6">
              <label class="form-label"> First Name (<span style="color: red">*</span>) </label>
              <input type="text" name="name_first" class="form-control" placeholder="Enter first name" />
            </div>
            <div class="col-md-6">
              <label class="form-label"> Last Name (<span style="color: red">*</span>) </label>
              <input type="text" name="name_last" class="form-control" placeholder="Enter last name" />
            </div>

            <div class="col-md-6">
              <label class="form-label"> Handicap </label>
              <input type="number" name="handicap" class="form-control" placeholder="0.0" />
            </div>

            <div class="col-md-6">
              <label class="form-label"> Year Joined </label>
              <input type="number" name="year_joined" class="form-control" placeholder="2026" />
            </div>

            <div class="col-md-6">
              <input type="text" name="password" class="form-control" placeholder="password" />
            </div>
          </div>
        </div>

        <!-- CONTACT -->
        <div class="form-section">
          <h3>Contact Information</h3>

          <div class="row g-4">
            <div class="col-md-6">
              <label class="form-label"> Email Address (<span style="color: red">*</span>) </label>

              <input type="email" name="e_mail" class="form-control" placeholder="player@email.com" />
            </div>

            <div class="col-md-6">
              <label class="form-label"> Phone Number (<span style="color: red">*</span>) </label>

              <input type="tel" name="phone" class="form-control" placeholder="(555) 555-5555" />
            </div>
          </div>
        </div>

        <!-- LEAGUE -->
        <div class="form-section">
          <h3>League Settings</h3>

          <div class="row g-4">
            <div class="col-md-6">
              <label class="form-label"> Active (<span style="color: red">*</span>) </label>

              <select class="form-select" name="status">
                <option selected>True or False</option>
                <option>true</option>
                <option>false</option>
              </select>
            </div>

            <div class="col-md-6">
              <label class="form-label"> Status (<span style="color: red">*</span>) </label>

              <select class="form-select" name="type">
                <option selected>Regular or Substitute</option>
                <option>Regular</option>
                <option>Substitute</option>
              </select>
            </div>
          </div>
        </div>

        <!-- SUBMIT -->
        <div class="text-center mt-4">
          <button type="submit" class="btn btn-submit-player">Add Player</button>
        </div>
      </form>
    </div>
  </div>
</body>
<%- include('layouts/scripts'); %>

</html>