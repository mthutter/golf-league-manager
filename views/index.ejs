<!doctype html>
<html lang="en">
  <!-- header section -->
  <%- include('./layouts/header'); -%>

  <style>
    /* MAIN LAYOUT */
    .main-grid {
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      align-items: center;
      justify-items: center;
      gap: 20px;

      max-width: 1200px;
      margin: 0 auto;
      padding: 10px;
    }

    /* CENTER CONTENT */
    .center-content {
      width: 100%;
      max-width: 600px;
      padding: 16px;
      text-align: center;
    }

    .center-content .title {
      color: red;
      font-size: clamp(16px, 4.5vw, 28px);
      margin-bottom: 12px;
    }

    .center-content p {
      font-size: clamp(12px, 3.5vw, 20px);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      margin: 4px 0;
      letter-spacing: 0.3px;
    }

    .center-content .first {
      color: aqua;
      font-weight: bold;
    }

    /* SIDE IMAGES */
    .side-image img {
      width: clamp(80px, 15vw, 200px);
      height: auto;
      border: 3px solid black;
      border-radius: 0.75rem;
      display: block;
    }

    /* MOBILE (STACKED) */
    @media (max-width: 768px) {
      .main-grid {
        grid-template-columns: 1fr;
      }

      .side-image img {
        width: clamp(100px, 40vw, 180px);
      }
    }

    /* SMALL PHONES */
    @media (max-width: 480px) {
      .side-image {
        display: none;
      }
    }

    /* LANDSCAPE PHONES */
    @media (max-height: 500px) and (orientation: landscape) {
      .side-image {
        display: none;
      }

      .main-grid {
        grid-template-columns: 1fr;
        gap: 10px;
      }

      .center-content {
        max-width: 100%;
        padding: 10px;
      }

      .center-content p {
        font-size: clamp(10px, 2.5vw, 14px);
      }

      .center-content .title {
        font-size: 14px;
      }
    }
  </style>

  <body>
    <!-- Google Tag Manager (noscript) -->
    <noscript>
      <iframe src="https://www.googletagmanager.com/ns.html?id=GTM-W9Q82T2S" height="0" width="0" style="display: none; visibility: hidden"></iframe>
    </noscript>

    <section id="navbar"><%- include('./layouts/navbar'); -%></section>

    <section class="main-wrapper">
      <div class="main-grid">
        <div class="side-image">
          <a href="">
            <img src="/images/2025/Bottom's%20Up%20Squatch.webp" alt="Bottoms Up Logo" />
          </a>
        </div>

        <div class="center-content main-schedule">
          <h2 class="title">2025 WINNERS</h2>

          <p class="first">First Place - Jon Dickey (20.18)</p>
          <p>Second Place - Matthew Shirola (19.92)</p>
          <p>Third Place - Jeff Vest (19.89)</p>
          <p>CTP - Ryan Miller (4)</p>
        </div>

        <div class="side-image">
          <a href="">
            <img src="/images/2025/Bottom's%20Up%20Squatch.webp" alt="Bottoms Up Logo" />
          </a>
        </div>
      </div>
    </section>

    <section id="footer"><%- include('./layouts/footer'); -%></section>
  </body>
</html>
